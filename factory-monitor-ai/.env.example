# ---- Postgres ----
POSTGRES_USER=factory
POSTGRES_PASSWORD=factory
POSTGRES_DB=factory
# async URL used by the app/tests (asyncpg)
DATABASE_URL=postgresql+asyncpg://factory:factory@localhost:5432/factory
# sync URL used by Alembic
ALEMBIC_DATABASE_URL=postgresql://factory:factory@localhost:5432/factory

# ---- Kafka ----
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_ANOMALIES_TOPIC=vision.anomalies.v1
KAFKA_DLQ_TOPIC=vision.anomalies.dlq
KAFKA_CONSUMER_GROUP=ingest-worker

# ---- Redis ----
REDIS_URL=redis://localhost:6379/0

# ---- App ----
OPERATOR_GRACE_SECONDS=120

# ---- Phase 2a (escalation + notifier) ----
# Provider chain: comma-separated, left=preferred. 'console' = zero-cred demo default.
# Add 'whatsapp' or 'sms' when Twilio creds are supplied.
NOTIFY_PROVIDER_CHAIN=console
ESCALATION_LEASE_SECONDS=30

# ---- Phase 2b (live WebSocket fan-out) ----
# Redis pub/sub channel producers PUBLISH incident events to; the API /ws/live
# subscriber consumes it.  Postgres-poll fallback fires every WS_FALLBACK_POLL_SECONDS
# when Redis is unavailable (failure-table 'Redis down' row).
WS_REDIS_CHANNEL=dashboard:incidents
WS_FALLBACK_POLL_SECONDS=1.0
WS_FALLBACK_BATCH=200

# ---- Phase 3b.1 / 3b.3 (Observability — traces + metrics) ----
# Base OTLP HTTP endpoint; telemetry.py appends /v1/traces automatically.
# Set when running the obs stack: docker compose -f compose.yaml -f compose.observability.yaml --profile obs up
#OTEL_EXPORTER_OTLP_ENDPOINT=

# Prometheus scrape ports exposed by each worker (used in prometheus.yml)
INGEST_METRICS_PORT=9101
ESCALATION_METRICS_PORT=9102
NOTIFIER_METRICS_PORT=9103
API_METRICS_PORT=9104
