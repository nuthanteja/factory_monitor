{
  "uid": "fm-camera-liveness",
  "title": "Camera Liveness",
  "schemaVersion": 39,
  "tags": ["factory-monitor"],
  "timezone": "browser",
  "time": {"from": "now-1h", "to": "now"},
  "panels": [
    {
      "id": 1,
      "title": "Camera staleness (s)",
      "type": "stat",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "time() - cam_last_frame_seconds",
          "legendFormat": "{{camera_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 30}
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Edge heartbeat rate",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "rate(edge_heartbeat_total[1m])",
          "legendFormat": "{{node}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Frame ingest rate / camera",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "rate(frames_in_total[1m])",
          "legendFormat": "{{camera_id}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Camera last-frame age (s)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "time() - cam_last_frame_seconds",
          "legendFormat": "{{camera_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 30}
            ]
          }
        }
      }
    }
  ]
}
