{
  "uid": "fm-worker-fleet-hpa",
  "title": "Worker Fleet & HPA",
  "schemaVersion": 39,
  "tags": ["factory-monitor"],
  "timezone": "browser",
  "time": {"from": "now-1h", "to": "now"},
  "panels": [
    {
      "id": 1,
      "title": "Targets up by job",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (job) (up{job=~\"ingest_worker|escalation_worker|notifier_worker|api|edge\"})",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Claim latency p50/p95",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum by (le) (rate(escalation_claim_latency_seconds_bucket{job=\"escalation_worker\"}[5m])))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(escalation_claim_latency_seconds_bucket{job=\"escalation_worker\"}[5m])))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 3,
      "title": "Per-instance consume rate",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (instance) (rate(ingest_events_consumed_total{job=\"ingest_worker\"}[1m]))",
          "legendFormat": "{{instance}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Per-instance fire rate",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (instance) (rate(escalations_fired_total{job=\"escalation_worker\"}[1m]))",
          "legendFormat": "{{instance}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "HPA replicas over time",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 16},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "kube_horizontalpodautoscaler_status_current_replicas{horizontalpodautoscaler=~\"keda-hpa-.*\"}",
          "legendFormat": "{{horizontalpodautoscaler}}"
        }
      ]
    }
  ]
}
